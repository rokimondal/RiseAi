generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  clerkUserId        String              @unique
  email              String              @unique
  name               String?
  imageUrl           String?
  industry           String?
  createdAt          DateTime            @default(now())
  updateAt           DateTime            @updatedAt
  bio                String?
  experience         Int?
  skills             String[]
  credits            Int                 @default(20)
  creditTransactions CreditTransaction[]
  assessments        Assessment[]
  coverLetter        CoverLetter[]
  appliedJobs        AppliedJob[]
  simulationSessions SimulationSession[]
  simulationResults  SimulationResult[]
  resume             Resume?
  industryInsight    IndustryInsight?    @relation(fields: [industry], references: [industry])
}

model Assessment {
  id             String   @id @default(cuid())
  userId         String
  quizScore      Float
  questions      Json[]
  category       String
  createdAt      DateTime @default(now())
  updateAt       DateTime @updatedAt
  improvementTip String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Resume {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   String
  atsScore  Float?
  feedback  String?
  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoverLetter {
  id             String   @id @default(cuid())
  userId         String
  content        String
  jobDescription String?
  companyName    String
  jobTitle       String
  status         String   @default("draft") // draft, completed
  createdAt      DateTime @default(now())
  updateAt       DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IndustryInsight {
  id                String        @id @default(cuid())
  industry          String        @unique
  salaryRanges      Json[]
  growthRate        Float
  demandLevel       DemandLevel
  topSkills         String[]
  marketOutlook     MarketOutlook
  recommendedSkills String[]
  lastUpdated       DateTime      @default(now())
  nextUpdate        DateTime
  keyTrends         String[]
  jobSearchKeywords String[]
  users             User[]

  @@index([industry])
}

model AppliedJob {
  id            String            @id @default(cuid())
  userId        String
  externalJobId String
  source        String
  title         String
  company       String
  location      String?
  description   String?
  applyLink     String
  companyLogo   String?
  status        ApplicationStatus @default(APPLIED)
  notes         String?
  appliedAt     DateTime          @default(now())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalJobId])
  @@index([userId])
  @@index([externalJobId])
}

model SimulationSession {
  id               String            @id @default(cuid())
  sessionToken     String            @unique @default(cuid())
  userId           String
  type             SimulationType
  status           SessionStatus     @default(STARTED)
  payload          Json?
  startedAt        DateTime?
  submittedAt      DateTime?
  expiresAt        DateTime?
  durationSeconds  Int?
  autoSubmitted    Boolean           @default(false)
  creditsUsed      Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  result           SimulationResult?
  linkedSessionIds String[]          @default([])

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([type])
  @@index([status, expiresAt])
}

model SimulationResult {
  id             String             @id @default(cuid())
  sessionId      String?            @unique
  session        SimulationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId         String
  type           SimulationType
  score          Float
  metadata       Json?
  result         Json?
  improvementTip String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreditTransaction {
  id                String                @id @default(cuid())
  userId            String
  amount            Int
  balanceAfter      Int
  type              CreditTransactionType
  title             String
  description       String?
  externalPaymentId String?
  createdAt         DateTime              @default(now())
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum SessionStatus {
  STARTED
  SUBMITTED
  EVALUATION_PENDING
  EXPIRED
}

enum ApplicationStatus {
  SAVED
  APPLIED
  REJECTED
  OFFER
}

enum SimulationType {
  MOCK_INTERVIEW
  COMPANY_SIMULATION
  CODING_ROUND
  ASSESSMENT_CENTER
}

enum DemandLevel {
  HIGH
  MEDIUM
  LOW
}

enum MarketOutlook {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum CreditTransactionType {
  BONUS
  PURCHASE
  USAGE
  REFUND
  ADMIN_ADDED
}
